# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=                        # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=                  # optional — for webhook signature verification

# ─── Linear OAuth ─────────────────────────────────────────────────────────────
# Create at: https://linear.app/settings/api/applications
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ─── Jira OAuth (Atlassian) ───────────────────────────────────────────────────
# Create at: https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=                    # Create in Stripe Dashboard → Products
STRIPE_TEAM_PRICE_ID=

# ─── Database (PostgreSQL / Supabase) ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/speccop

# ─── Trigger.dev (optional — for async job processing) ───────────────────────
TRIGGER_SECRET_KEY=
